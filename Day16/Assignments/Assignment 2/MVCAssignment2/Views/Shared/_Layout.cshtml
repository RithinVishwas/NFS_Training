<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC Assignment 2</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin: 30px auto;
            padding: 0 20px;
            line-height: 1.5;
        }

        label {
            display: block;
            margin-top: 12px;
        }

        input {
            display: block;
            width: 100%;
            margin-top: 5px;
            padding: 8px;
        }

        button {
            margin-top: 15px;
            padding: 8px 14px;
            cursor: pointer;
        }

        .result {
            border: 1px solid #ccc;
            padding: 15px;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <main>
        @RenderBody()
    </main>
</body>
</html>
