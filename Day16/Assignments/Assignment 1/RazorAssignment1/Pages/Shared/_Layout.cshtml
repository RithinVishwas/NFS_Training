<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Razor Assignment 1</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 900px;
            margin: 30px auto;
            padding: 0 20px;
            line-height: 1.5;
        }

        input, textarea {
            display: block;
            width: 100%;
            margin: 6px 0 14px;
            padding: 8px;
        }

        button {
            padding: 8px 14px;
            cursor: pointer;
        }

        .product {
            border: 1px solid #ccc;
            padding: 12px;
            margin-bottom: 12px;
        }

        .categories a {
            margin-right: 8px;
        }
    </style>
</head>
<body>
    <main>
        @RenderBody()
    </main>
</body>
</html>
